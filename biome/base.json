{
  "$schema": "https://biomejs.dev/schemas/2.3.7/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": {
          "level": "error",
          "options": {
            "ignoreRestSiblings": true
          }
        }
      },
      "style": {
        "noDefaultExport": "error",
        "noProcessEnv": "error",
        "useImportType": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": [
                  "@vercel/**",
                  "@sentry/**",
                  "@datadog/**",
                  "@clerk/**",
                  "@auth0/**",
                  "@supabase/**",
                  "@upstash/**",
                  "@amplitude/**",
                  "@segment/**",
                  "@fullstory/**",
                  "@intercom/**",
                  "newrelic",
                  "dd-trace",
                  "logrocket",
                  "analytics-node",
                  "mixpanel-browser",
                  "mixpanel",
                  "hotjar",
                  "posthog-js",
                  "posthog-node",
                  "@hotjar/browser",
                  "bugsnag",
                  "rollbar",
                  "honeybadger",
                  "firebase/app",
                  "firebase/auth",
                  "firebase/firestore",
                  "firebase/database",
                  "appwrite",
                  "pocketbase",
                  "launchdarkly-node-server-sdk",
                  "launchdarkly-react-client-sdk",
                  "configcat-node",
                  "configcat-js",
                  "crisp-sdk-web",
                  "@langchain/**",
                  "langchain/**"
                ],
                "message": "Vendor SDK imports are restricted to infra adapters"
              },
              {
                "group": ["**/__arch_probes__/**", "@/__arch_probes__/**"],
                "message": "Architecture probe imports are forbidden outside of tests - probes are test-only fixtures"
              },
              {
                "group": ["@/shared/util"],
                "message": "Import from specific modules (e.g. @/shared/util/cn) not the barrel. The barrel re-exports server-only code (node:crypto) that breaks client component bundling."
              }
            ]
          }
        }
      },
      "nursery": {
        "useSortedClasses": {
          "level": "error",
          "options": {
            "attributes": ["class", "className"],
            "functions": ["cn", "clsx", "cva"]
          }
        }
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noConsole": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    },
    "globals": ["React"]
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["nodes/*/app/src/infra/**", "packages/langgraph-graphs/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": [
        "nodes/*/app/src/shared/env/**/*.ts",
        "nodes/*/app/src/shared/env/**/*.tsx",
        "nodes/*/app/src/auth.ts",
        "nodes/*/app/src/shared/observability/clientLogger.ts",
        "nodes/*/app/src/shared/observability/server/**/*.ts",
        "nodes/*/app/src/app/(infra)/readyz/route.ts",
        "e2e/**/*.{ts,tsx}",
        "playwright.config.ts",
        "tests/**/*.ts",
        "nodes/*/app/tests/**/*.ts",
        "scripts/**/*.{ts,mts,js,cjs,mjs}",
        "docs/templates/**/*.ts",
        "services/**/*.ts",
        "**/*.config.ts",
        "**/*.config.js",
        "**/*.config.cjs",
        "**/*.config.mts",
        "nodes/*/drizzle.config.ts",
        "nodes/*/drizzle.doltgres.config.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noProcessEnv": "off"
          }
        }
      }
    },
    {
      "includes": [
        "e2e/**/*.{ts,tsx}",
        "playwright.config.ts",
        "tests/**/*.{ts,tsx}",
        "nodes/*/app/tests/**/*.{ts,tsx}",
        "scripts/**/*.{ts,mts,js,cjs,mjs}",
        "services/**/*.ts",
        "**/*.config.ts",
        "**/*.config.js",
        "**/*.config.cjs",
        "**/*.config.mts",
        "nodes/*/drizzle.config.ts",
        "nodes/*/drizzle.doltgres.config.ts",
        "nodes/*/app/src/shared/observability/logging/logger.ts",
        "nodes/*/app/src/shared/observability/clientLogger.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.d.ts"],
      "formatter": { "enabled": false },
      "linter": { "enabled": false }
    },
    {
      "includes": ["tests/**/fixtures/**"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false }
    },
    {
      "includes": [
        "nodes/operator/app/src/**/__arch_probes__/**",
        "nodes/*/app/src/**/__arch_probes__/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "off"
            }
          }
        }
      }
    },
    {
      "includes": [
        "packages/ai-core/tsup.config.ts",
        "packages/ai-core/vitest.config.ts",
        "packages/ai-tools/tsup.config.ts",
        "packages/ai-tools/vitest.config.ts",
        "packages/authorization-core/tsup.config.ts",
        "packages/authorization-core/vitest.config.ts",
        "packages/aragon-osx/tsup.config.ts",
        "packages/cogni-contracts/tsup.config.ts",
        "packages/langgraph-graphs/tsup.config.ts",
        "packages/langgraph-graphs/vitest.config.ts",
        "packages/langgraph-graphs/vitest.external.config.ts",
        "packages/graph-execution-core/tsup.config.ts",
        "packages/scheduler-core/tsup.config.ts",
        "packages/db-client/tsup.config.ts",
        "packages/ids/tsup.config.ts",
        "packages/ids/vitest.config.ts",
        "packages/db-schema/tsup.config.ts",
        "packages/ingestion-core/tsup.config.ts",
        "packages/attribution-ledger/tsup.config.ts",
        "packages/repo-spec/tsup.config.ts",
        "packages/attribution-pipeline-contracts/tsup.config.ts",
        "packages/attribution-pipeline-contracts/vitest.config.ts",
        "packages/attribution-pipeline-plugins/tsup.config.ts",
        "packages/operator-wallet/tsup.config.ts",
        "packages/operator-wallet/vitest.config.ts",
        "packages/attribution-pipeline-plugins/vitest.config.ts",
        "packages/financial-ledger/tsup.config.ts",
        "packages/financial-ledger/vitest.config.ts",
        "packages/temporal-workflows/tsup.config.ts",
        "packages/temporal-workflows/vitest.config.ts",
        "packages/work-items/tsup.config.ts",
        "packages/work-items/vitest.config.ts",
        "packages/node-core/tsup.config.ts",
        "packages/node-contracts/tsup.config.ts",
        "packages/node-shared/tsup.config.ts",
        "packages/graph-execution-host/tsup.config.ts",
        "packages/graph-execution-host/vitest.config.ts",
        "services/scheduler-worker/tsup.config.ts",
        "services/scheduler-worker/vitest.config.ts",
        "vitest.workspace.ts",
        "nodes/*/app/vitest.component.config.mts",
        "nodes/*/app/vitest.external.config.mts",
        "nodes/*/app/vitest.stack.config.mts",
        "nodes/*/app/vitest.config.mts",
        "nodes/*/app/vitest.external-money.config.mts",
        "nodes/*/app/postcss.config.mjs",
        "nodes/*/app/next.config.ts",
        "nodes/*/graphs/tsup.config.ts",
        "nodes/*/drizzle.config.ts",
        "nodes/*/drizzle.doltgres.config.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
