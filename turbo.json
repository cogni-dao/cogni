{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "pnpm-lock.yaml",
    "tsconfig.base.json",
    "biome.json",
    ".env.local.example",
    ".env.test.example",
    ".env.docker.example"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "tsconfig*.json",
        "tsup.config.*",
        "next.config.*",
        "package.json"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "inputs": ["src/**", "tests/**", "tsconfig*.json", "package.json"]
    },
    "lint": {
      "inputs": ["src/**", "tests/**", "*.config.*", "package.json"]
    },
    "test": {
      "inputs": [
        "src/**",
        "tests/**",
        "vitest*.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": [
        "NODE_ENV",
        "APP_ENV",
        "DATABASE_URL",
        "DATABASE_SERVICE_URL",
        "COGNI_REPO_PATH",
        "LITELLM_MASTER_KEY",
        "AUTH_SECRET",
        "SCHEDULER_API_TOKEN",
        "BILLING_INGEST_TOKEN",
        "INTERNAL_OPS_TOKEN",
        "DISCORD_BOT_TOKEN",
        "POSTHOG_API_KEY",
        "POSTHOG_HOST",
        "TEMPORAL_ADDRESS",
        "TEMPORAL_NAMESPACE",
        "TEMPORAL_TASK_QUEUE"
      ]
    },
    "test:external": {
      "inputs": [
        "src/**",
        "tests/**",
        "vitest*.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": [
        "NODE_ENV",
        "APP_ENV",
        "DATABASE_URL",
        "GH_REVIEW_APP_ID",
        "GH_REVIEW_APP_PRIVATE_KEY_BASE64",
        "GITHUB_TOKEN",
        "GH_TOKEN",
        "E2E_GITHUB_REPO",
        "OLLAMA_URL"
      ]
    },
    "test:external:money": {
      "inputs": [
        "src/**",
        "tests/**",
        "vitest*.config.*",
        "tsconfig*.json",
        "package.json"
      ],
      "env": [
        "NODE_ENV",
        "APP_ENV",
        "DATABASE_URL",
        "OPENROUTER_PROVISIONING_KEY",
        "OPENROUTER_WALLET_SEED_PHRASE"
      ]
    },
    "//#lint": {
      "inputs": [
        "biome.json",
        "biome/*.json",
        "eslint.config.*",
        ".eslintrc*",
        ".eslintignore",
        "package.json",
        "nodes/*/app/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
        "!nodes/*/app/src/components/reui/**",
        "packages/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
        "services/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
        "tests/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
        "scripts/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
        "infra/compose/**/*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}",
        "*.{ts,tsx,js,jsx,mjs,cjs,mts,cts,json}"
      ]
    },
    "//#format:check": {
      "inputs": [
        "**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml}",
        "biome.json",
        "biome/*.json",
        "package.json",
        ".prettierrc*",
        ".prettierignore",
        "!**/dist/**",
        "!**/.next/**",
        "!**/node_modules/**"
      ]
    },
    "//#db:check": {
      "inputs": [
        "nodes/*/drizzle.config.ts",
        "nodes/*/drizzle.doltgres.config.ts",
        "nodes/*/packages/db-schema/**",
        "nodes/*/packages/doltgres-schema/**",
        "nodes/*/migrations/**"
      ]
    }
  }
}
