{
  "name": "@cogni/temporal-workflows",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./scheduler": {
      "types": "./dist/scheduler.d.ts",
      "import": "./dist/scheduler.js",
      "default": "./dist/scheduler.js"
    },
    "./ledger": {
      "types": "./dist/ledger.d.ts",
      "import": "./dist/ledger.js",
      "default": "./dist/ledger.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "postbuild": "node -e \"const fs=require('fs'); if(!fs.existsSync('dist/index.js')){console.error('ERROR: dist/index.js missing'); process.exit(1)}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cogni/attribution-ledger": "workspace:*",
    "@cogni/ingestion-core": "workspace:*",
    "@cogni/knowledge-store": "workspace:*",
    "@cogni/node-contracts": "workspace:*",
    "@cogni/repo-spec": "workspace:*",
    "@temporalio/workflow": "^1.11.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
