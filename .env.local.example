# Development Environment Variables
# Copy this to .env.local (never commit .env.local)

# Node environment
NODE_ENV=development

# Application environment (controls adapter wiring)
APP_ENV=production
# APP_ENV=test  # Uncomment to use fake adapters locally (CI sets this automatically)

# =============================================================================
# Next.js App
# =============================================================================

# App runtime (used by Next.js server/runtime only)
APP_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
DOMAIN=localhost

# ── Database ──────────────────────────────────────────────────────────────────
# Per DATABASE_RLS_SPEC.md design decision 7: runtime app consumes explicit DSNs only.
# Per multi-node-tenancy spec DB_PER_NODE: each node gets its own database.
# Both DSNs required per node. Users MUST be distinct (RLS enforcement requires role separation).
# Run `pnpm db:provision:nodes` to create all node databases + roles.
#
# Operator (default — backward compatible with single-node workflows)
# app_user role (RLS enforced) — used by Next.js request paths
DATABASE_URL="postgresql://app_user:password@localhost:55432/cogni_operator"
# app_service role (BYPASSRLS) — used by auth, workers, bootstrap
DATABASE_SERVICE_URL="postgresql://app_service:service_password@localhost:55432/cogni_operator"
# Docker-internal variant — used by scheduler-worker container
DATABASE_SERVICE_URL_DOCKER="postgresql://app_service:service_password@postgres:5432/cogni_operator"

# Per-node database URLs (DB_PER_NODE — each node has its own database)
DATABASE_URL_POLY="postgresql://app_user:password@localhost:55432/cogni_poly"
DATABASE_SERVICE_URL_POLY="postgresql://app_service:service_password@localhost:55432/cogni_poly"
DATABASE_URL_RESY="postgresql://app_user:password@localhost:55432/cogni_resy"
DATABASE_SERVICE_URL_RESY="postgresql://app_service:service_password@localhost:55432/cogni_resy"

# ── Docker stack provisioning (docker:stack:setup only) ───────────────────────
# These feed provision.sh which creates app_user + app_service roles.
# Not used by the Next.js app directly — only consumed by db-provision container.
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASSWORD=postgres
# COGNI_NODE_DBS: comma-separated list of node databases to create (DB_PER_NODE)
COGNI_NODE_DBS=cogni_operator,cogni_poly,cogni_resy,cogni_node_template
APP_DB_USER=app_user
APP_DB_PASSWORD=password
APP_DB_SERVICE_USER=app_service
APP_DB_SERVICE_PASSWORD=service_password
APP_DB_READONLY_USER=app_readonly
APP_DB_READONLY_PASSWORD=readonly_password

# ── Doltgres (Knowledge Data Plane) ─────────────────────────────────────────
# Versioned knowledge store. Per knowledge-data-plane spec.
# Per-node pattern: DOLTGRES_URL_<NODE> — same convention as DATABASE_URL_<NODE>.
# Provisioned by doltgres-provision container (bootstrap profile).
DOLTGRES_PASSWORD=doltgres
DOLTGRES_READER_PASSWORD=knowledge_reader
DOLTGRES_WRITER_PASSWORD=knowledge_writer
# Per-node DSNs (knowledge_writer role: read + write + dolt_commit)
DOLTGRES_URL_OPERATOR="postgresql://knowledge_writer:knowledge_writer@localhost:5435/knowledge_operator"
DOLTGRES_URL_POLY="postgresql://knowledge_writer:knowledge_writer@localhost:5435/knowledge_poly"
DOLTGRES_URL_RESY="postgresql://knowledge_writer:knowledge_writer@localhost:5435/knowledge_resy"

# ── Auth (per multi-node-tenancy spec: ORIGIN_SCOPED_COOKIES) ────────────────
# Each node gets its own secret so tokens minted by one node can't be verified by another.
# Generate each with: openssl rand -base64 32
AUTH_SECRET="operator-dev-secret-at-least-32-characters-long-change"
AUTH_SECRET_POLY="poly-dev-secret-at-least-32-characters-change-me!!"
AUTH_SECRET_RESY="resy-dev-secret-at-least-32-characters-change-me!!"

# OAuth Providers (multi-provider auth — login + account linking)
# Only providers with both CLIENT_ID and CLIENT_SECRET set will be registered.

# GitHub: https://github.com/settings/developers → OAuth Apps → New
# Callback URL: http://localhost:3000/api/auth/callback/github
GH_OAUTH_CLIENT_ID=
GH_OAUTH_CLIENT_SECRET=

# Discord: https://discord.com/developers/applications → New Application → OAuth2
# Callback URL: http://localhost:3000/api/auth/callback/discord
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials → Create OAuth client ID
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# LLM Integration (Stage 8) - LITELLM_BASE_URL auto-detects based on NODE_ENV
# Default models are computed from LiteLLM catalog metadata (metadata.cogni.default_preferred/default_free)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=your-litellm-master-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenClaw Gateway (sandbox-openclaw profile)
# Auth token for gateway WS handshake — must match openclaw-gateway.json gateway.auth.token
# Generate with: openssl rand -base64 32
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token-min32ch
# Git relay (host-side push + PR). Requires Contents:Write + Pull requests:Write.
OPENCLAW_GITHUB_RW_TOKEN=ghp_your-github-rw-token-here
# Discord bot token for OpenClaw gateway channel
# Get from: discord.com/developers/applications → your app → Bot → Reset Token
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# LangGraph Dev Server (Optional)
# Set to enable langgraph dev server execution instead of in-process.
# Start server with: pnpm langgraph:dev
# Default port for langgraph dev: 2024
# LANGGRAPH_DEV_URL=http://localhost:2024

# LangSmith API Key (only for langgraph dev server, not loaded by Next.js)
# Required by LangGraph Studio/dev server for tracing.
# Get from: https://smith.langchain.com → Settings → API Keys
# LANGSMITH_API_KEY=lsv2_pt_your-api-key-here

# Optional server config
PORT=3000
PINO_LOG_LEVEL=debug

# ── Observability ─────────────────────────────────────────────────────────────

# Log Collection (Alloy → Loki)
# For local dev: Uses local Loki (no cloud credentials needed, auto-configured by docker-compose.dev.yml)
# DEPLOY_ENVIRONMENT=local  # Auto-set by docker-compose.dev.yml, no need to define
# LOKI_WRITE_URL=http://loki:3100/loki/api/v1/push  # Auto-set by docker-compose.dev.yml
# LOKI_USERNAME=  # Empty for local dev (auto-set by docker-compose.dev.yml)
# LOKI_PASSWORD=  # Empty for local dev (auto-set by docker-compose.dev.yml)

# Optional: Override to send local logs to Grafana Cloud instead (not recommended for dev)
# DEPLOY_ENVIRONMENT=local
# LOKI_WRITE_URL="https://logs-prod-020.grafana.net/loki/api/v1/push"
# LOKI_USERNAME="123456"  # Your numeric user ID
# LOKI_PASSWORD="glc_your_api_key_here"  # API key with logs:write permission

# Prometheus Metrics (Stage 9)
# Token for /api/metrics endpoint authentication (min 32 chars, required in production)
METRICS_TOKEN=local-dev-metrics-token-32chars!

# Optional: Prometheus metrics (Grafana Cloud)
# WRITE path (Alloy remote_write) - write-only token
# PROMETHEUS_REMOTE_WRITE_URL="https://prometheus-prod-37-prod-ap-southeast-1.grafana.net/api/prom/push"
# PROMETHEUS_USERNAME="123456"  # Your numeric user ID
# PROMETHEUS_PASSWORD="glc_write_token_here"  # API key with metrics:write ONLY

# READ path (app queries) - read-only token (separate from write for least privilege)
# PROMETHEUS_QUERY_URL is auto-derived from PROMETHEUS_REMOTE_WRITE_URL (strips /push)
# PROMETHEUS_READ_USERNAME="123456"  # Same user ID is fine
# PROMETHEUS_READ_PASSWORD="glc_..."  # Create at https://grafana.com/orgs/<org>/access-policies → metrics:read scope

# MCP (Model Context Protocol) — External tool servers
# Path to config file with MCP server definitions (see config/mcp.servers.json)
# When set, agents can use tools from configured MCP servers (Playwright, Grafana, etc.)
MCP_CONFIG_PATH="./config/mcp.servers.json"

# Grafana Observability (required for governance agents)
# Used by: MCP tools (log queries) + grafana-health skill (metrics/alerts)
# For local dev: Use grafana-local MCP (http://localhost:3001) or cloud (https://your-org.grafana.net)
# Generate token: Grafana → Administration → Service accounts → Add token (Viewer role)
GRAFANA_URL="https://your-org.grafana.net"
GRAFANA_SERVICE_ACCOUNT_TOKEN="glsa_your_service_account_token_here"

# PostHog - Product Analytics (Required, mock values ok in local dev)
# Self-hosted: pnpm posthog:up → http://localhost:8000 → copy project API key
# Cloud (recommended): Sign up at posthog.com → free tier 1M events/month
POSTHOG_API_KEY=phc_your_project_api_key_here
POSTHOG_HOST=http://localhost:8000
POSTHOG_PROJECT_ID=1

# Tavily - Web search for AI tools (Optional)
# Without this, the WebSearchCapability is unavailable and any AI tool that
# requests core__web_search will fail with "WebSearchCapability not configured".
# Get a key: https://app.tavily.com/home (free tier available)
# TAVILY_API_KEY=tvly-your_api_key_here

# Langfuse - AI Observability (Optional)
# When set, AI completions are traced to Langfuse for debugging and eval.
# Get keys from: https://cloud.langfuse.com → Settings → API Keys
# LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
# LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# LANGFUSE_BASE_URL=https://cloud.langfuse.com  # Optional, defaults to cloud. Use for self-hosted.

# ── Internal API tokens ───────────────────────────────────────────────────────
# These tokens authenticate service-to-service calls. All min 32 chars.

# Scheduler API token - auth for scheduler-worker → internal graph execution API
# Used by scheduler-worker to call POST /api/internal/graphs/{graphId}/runs
# Generate with: openssl rand -base64 32
SCHEDULER_API_TOKEN=local-dev-scheduler-api-token-min32chars

# Billing ingest token - auth for LiteLLM generic_api callback → billing ingest endpoint
# Used by LiteLLM to call POST /api/internal/billing/ingest
BILLING_INGEST_TOKEN=local-dev-billing-ingest-token-min32ch

# Internal ops token - auth for deploy-time governance sync trigger endpoint
# Used by deploy helpers to call POST /api/internal/ops/governance/schedules/sync
INTERNAL_OPS_TOKEN=local-dev-internal-ops-token-min32ch

# Per-node billing callback routing (custom LiteLLM callback class)
# Required. Format: node_id_uuid=endpoint_url,node_id_uuid=endpoint_url,...
# Keys are node_id UUIDs from .cogni/repo-spec.yaml (per REPO_SPEC_AUTHORITY).
# Must match nodes[] in operator repo-spec. See: docs/spec/multi-node-tenancy.md
# For pnpm dev:stack (single-node, app on host):
#   COGNI_NODE_ENDPOINTS=4ff8eac1-4eba-4ed0-931b-b1fe4f64713d=http://host.docker.internal:3000/api/internal/billing/ingest
# For pnpm docker:stack (app in Docker):
#   COGNI_NODE_ENDPOINTS=4ff8eac1-4eba-4ed0-931b-b1fe4f64713d=http://app:3000/api/internal/billing/ingest
# For pnpm dev:stack:full (multi-node, apps on host):
COGNI_NODE_ENDPOINTS=4ff8eac1-4eba-4ed0-931b-b1fe4f64713d=http://host.docker.internal:3000/api/internal/billing/ingest,5ed2d64f-2745-4676-983b-2fb7e05b2eba=http://host.docker.internal:3100/api/internal/billing/ingest,f6d2a17d-b7f6-4ad1-a86b-f0ad2380999e=http://host.docker.internal:3300/api/internal/billing/ingest

# ── Redis (stream plane) ──────────────────────────────────────────────────────
# Ephemeral stream data only (no durable state). Per unified-graph-launch spec.
# Default: redis://localhost:6379 (host-mode dev). Docker-compose overrides to redis://redis:6379.
# REDIS_URL=redis://localhost:6379

# =============================================================================
# Scheduler Worker (services/scheduler-worker)
# =============================================================================

# Temporal Schedule Orchestration (required)
# App requires Temporal - start with: pnpm dev:infra
# Use localhost for host-mode dev (pnpm dev); docker-compose overrides for container-mode
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=cogni-production
TEMPORAL_TASK_QUEUE=scheduler-tasks

# Temporal DB (compose-only, app never uses these):
# TEMPORAL_DB_HOST=temporal-postgres
# TEMPORAL_DB_PORT=5432
# TEMPORAL_DB_USER=temporal
# TEMPORAL_DB_PASSWORD=temporal

# Scheduler worker per-node API endpoints - how the scheduler-worker (in Docker) reaches node apps
# For pnpm dev:stack (app runs natively on host): use host.docker.internal
# For pnpm docker:stack (app runs in Docker): leave unset (defaults in compose)
COGNI_NODE_ENDPOINTS=operator=http://host.docker.internal:3000
SCHEDULER_WORKER_HEALTH_URL=http://localhost:9001

# GitHub App for ingestion (optional — only needed for GitHub activity collection)
# Create a GitHub App in your org, then set these:
# GH_REVIEW_APP_ID=123456
# GH_REVIEW_APP_PRIVATE_KEY_BASE64=<base64-encoded PEM>
# GH_REPOS=owner/repo1,owner/repo2
# GH_WEBHOOK_SECRET=your-webhook-secret-here
# GH_WEBHOOK_PROXY_URL=https://smee.io/your-channel  # local dev only — see docs/guides/github-app-webhook-setup.md

# Alchemy webhook for on-chain governance signal execution (optional)
# Required when CogniDAO governance loop is enabled (on-chain vote → GitHub action)
# ALCHEMY_WEBHOOK_SECRET=your-alchemy-signing-key
# ALCHEMY_PROXY_URL=https://smee.io/your-alchemy-channel  # local dev only — see docs/guides/alchemy-webhook-setup.md

# =============================================================================
# Shared / Cross-cutting
# =============================================================================

# EVM RPC - On-chain verification (Base mainnet)
# Get free API key from: alchemy.com or infura.io
EVM_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your-api-key-here

# Polygon RPC - poly-node reads USDC.e / POL balances on Polygon mainnet (chain 137).
# Separate from EVM_RPC_URL — different chain, different Alchemy app.
# Get from: alchemy.com (create a Polygon Mainnet app under the same account).
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-api-key-here

# Public client vars
# Wallet Integration
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=get-from-walletconnect-cloud  # Get from cloud.walletconnect.com

# Crypto widget payments (DePay) - crypto-only credits
# DAO receiving wallet + chain come from .cogni/repo-spec.yaml (no env override)

# TigerBeetle (Financial Ledger) — Optional
# When set, double-entry co-writes are enabled alongside Postgres.
# Requires: pnpm dev:infra:tb (opt-in, needs ~1.2GiB RAM for TigerBeetle)
# TIGERBEETLE_ADDRESS=127.0.0.1:3002

# Privy (Operator Wallet) — Optional
# Required only when operator wallet features are enabled.
# Without these, operator wallet adapter is undefined and treasury settlement silently no-ops.
# Create account at privy.io → App Settings → grab credentials.
# PRIVY_APP_ID=your-privy-app-id
# PRIVY_APP_SECRET=your-privy-app-secret
# PRIVY_SIGNING_KEY=wallet-auth:MIGHAgEA...

# Polymarket single-operator prototype wallet (POLY_PROTO_* + POLY_CLOB_API_* +
# POLY_CLOB_PASSPHRASE + POLY_PROTO_WALLET_ADDRESS) has been PURGED as of
# task.0318 Phase B Stage 4. The per-tenant trading wallets below replace it
# end-to-end — there is no single-tenant fallback path. If you still have
# those env vars set in a local .env.local from an older worktree, drop them:
# they're no longer read by the app.

# Copy-trade target wallets are now per-user records in `poly_copy_trade_targets`
# (RLS-scoped). Add via the dashboard or POST /api/v1/poly/copy-trade/targets;
# a system-tenant default seeds via migration 0029. Per docs/spec/poly-multi-tenant-auth.md.

# task.0318 Phase B — per-user Polymarket trading wallets.
# DEDICATED Privy app (SEPARATE_PRIVY_APP invariant) — MUST be different from
# PRIVY_APP_ID above. See docs/spec/poly-trader-wallet-port.md § Env for the
# rationale (Privy-side rate limits + audit + rotation isolation).
# PRIVY_USER_WALLETS_APP_ID=your-user-wallets-privy-app-id
# PRIVY_USER_WALLETS_APP_SECRET=your-user-wallets-privy-app-secret
# PRIVY_USER_WALLETS_SIGNING_KEY=wallet-auth:MIGHAgEA...
# AEAD key for poly_wallet_connections.clob_api_key_ciphertext (32 bytes / 64 hex).
# Generate: openssl rand -hex 32
# POLY_WALLET_AEAD_KEY_HEX=
# POLY_WALLET_AEAD_KEY_ID=v1
# Optional Polymarket-provided token used by the CLOB SDK as geo_block_token
# when server-side credential provisioning is blocked upstream.
# POLY_CLOB_GEO_BLOCK_TOKEN=

# BYO-AI: Connection encryption key — Optional
# AEAD encryption key for storing OAuth tokens (e.g., ChatGPT) in the connections table.
# Generate with: openssl rand -hex 32
# Without this, BYO-AI provider connections are disabled.
# CONNECTIONS_ENCRYPTION_KEY=your-64-hex-char-key-here

# Development tokens (replace with your own)
CHERRY_AUTH_TOKEN=your-cherry-auth-token-here
CR_PAT=your-github-pat-here

# Brain repo access (required — no default, no silent cwd fallback)
# "." = repo root for tests (cwd=root). Dev scripts set absolute path for apps/operator.
COGNI_REPO_PATH=.

# git-sync (required for all docker workflows: dev:infra, docker:dev:stack, docker:stack)
# The git-sync container clones the repo into a shared volume; the app reads /repo/current.
# Fine-grained PAT: Contents:Read scope, scoped to this repo (public repos work without token)
COGNI_REPO_URL=https://github.com/Cogni-DAO/cogni.git
COGNI_REPO_REF=HEAD
GIT_READ_USERNAME=your-github-username
GIT_READ_TOKEN=your-fine-grained-pat-here

# Test Environment Configuration
# Used by API integration tests in tests/api/**

# For dev:stack (Next.js runs locally, containers provide infrastructure)
TEST_BASE_URL=http://localhost:3000/

# For docker:stack (everything in containers, accessible via Caddy)
# TEST_BASE_URL=https://localhost/

# Remote environments
# TEST_BASE_URL=https://your-domain.com/

# =============================================================================
# DNS Operations (Cloudflare)
# =============================================================================

# Cloudflare DNS — Required for preview deploy subdomains and domain management.
# Setup guide: packages/dns-ops/docs/cloudflare-dns-setup.md
# 1. Create token: https://dash.cloudflare.com/profile/api-tokens → "Edit zone DNS" template
# 2. Get zone ID: Cloudflare dashboard → your domain → right sidebar → API section
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# CLOUDFLARE_ZONE_ID=your-zone-id-hex-string

# Billing Evolution Stage 6.5
USER_PRICE_MARKUP_FACTOR=2.0

# System tenant revenue share — fraction of user credits minted as bonus to system tenant
# 0 = disabled, 0.75 = 75% bonus (default). Per docs/spec/system-tenant.md
# SYSTEM_TENANT_REVENUE_SHARE=0.75
