# VCS
.git
.gitignore
.gitattributes

# Node / build artifacts (** matches nested paths in monorepo context)
**/node_modules
**/.next
**/build
**/coverage
**/out
**/.nyc_output

# Build outputs
**/dist
**/*.tsbuildinfo

# Claude Code worktrees (can be 30GB+)
.claude

# Env (don’t bake secrets into images)
.env*
.env.local
.env.development
.env.production

# OS / editor
.DS_Store
.vscode
.idea
*.swp
*.swo
*~

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Tests (if you never run them in Docker)
tests
e2e
playwright.config.ts
vitest*.config.*
test-results
playwright-report
tmp

# Architecture test fixtures (never needed in any Docker stage)
src/**/__arch_probes__

# CI / meta
.github
.gitlab-ci.yml
.travis.yml
.circleci

# Linting (not needed for build)
eslint.config.mjs
eslint/

# Misc cache
.cache
.pnpm-store
.yarn
.npm

# Infra / IaC (not needed in app images)
infra
scripts/ci
scripts/bootstrap

# Work items / docs (not needed in images)
work
docs
*.md
